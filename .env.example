# ── Nexus Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values

# LLM API key (required for narrative generation)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# JWT secret for session tokens (change this!)
JWT_SECRET=nexus-change-me-in-production

# Default admin password (admin@nexus.ai)
ADMIN_PASSWORD=admin123
