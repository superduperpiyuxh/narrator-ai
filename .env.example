# ── Nexus Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# The backend loads .env automatically on startup.

# OpenRouter API key for LLM narrative generation (required for narratives)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# JWT secret for session tokens (change in production)
JWT_SECRET=narrator-ai-jwt-secret

# Default admin password (admin@nexus.ai)
ADMIN_PASSWORD=admin123

# Server port
PORT=8080

# SQLite database path
DATABASE_PATH=./narratorai.db

# Sample data directory
DATA_DIR=../data/sample_json_20260301
